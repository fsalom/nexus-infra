# Copia a .env y ajusta.  NO subas .env al repo.
# (En despliegue por pipeline, esto va como secret INFRA_ENV.)

# Dominio base. Subdominios: auth.$DOMAIN, gastos.$DOMAIN, workout.$DOMAIN (DNS -> servidor).
DOMAIN=midominio.com

# Correo para los certificados TLS (Let's Encrypt).
ACME_EMAIL=tucorreo@ejemplo.com

# --- Postgres compartido (BBDD: microworkout, gastos, auth) ---
# Usa un password SIN caracteres especiales (hex): va dentro de la URL de conexión.
POSTGRES_USER=nexus
POSTGRES_PASSWORD=cambia-esto        # openssl rand -hex 24

# --- SSO (nexus-auth) ---
NEXUS_ADMIN_USER=admin
NEXUS_ADMIN_PASSWORD=cambia-esta-contraseña

# --- gastos ---
# El login lo pone el SSO; solo hace falta el token del cron.
GASTOS_CRON_TOKEN=                    # openssl rand -hex 24

# --- microworkout ---
WORKERS=2
# Ruta al .env de microworkout (SECRET_KEY, ALLOWED_HOSTS…; los POSTGRES_* los pone la infra).
# WORKOUT_ENV=../python-microworkout/.env
