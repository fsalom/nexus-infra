# Copia a .env y ajusta.  NO subas .env al repo.

# Dominio base. Se usan los subdominios gastos.$DOMAIN y workout.$DOMAIN
# (crea sus registros A/AAAA apuntando a este servidor).
DOMAIN=midominio.com

# Correo para los certificados TLS (Let's Encrypt).
ACME_EMAIL=tucorreo@ejemplo.com

# --- SSO (nexus-auth) ---
# Admin inicial del portal de identidad.
NEXUS_ADMIN_USER=admin
NEXUS_ADMIN_PASSWORD=cambia-esta-contraseña

# --- gastos ---
# El login de gastos lo pone el SSO; solo hace falta el token del cron.
GASTOS_CRON_TOKEN=            # openssl rand -hex 24

# --- microworkout ---
# Nº de workers de uvicorn para la API.
WORKERS=2
# Ruta al .env de microworkout (con POSTGRES_*, SECRET_KEY, etc.).
# Por defecto usa el del repo hermano; cámbialo si lo tienes en otro sitio.
# WORKOUT_ENV=../python-microworkout/.env
